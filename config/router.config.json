{
  "models": {
    "openrouter": {
      "minimax": "minimax/minimax-m2.7",
      "kimi": "moonshotai/kimi-k2.5"
    },
    "codex": {
      "default": "codex-default"
    },
    "claude": {
      "default": "claude-default"
    }
  },
  "version": 1,
  "state": {
    "default": "normal",
    "manual_state_file": "config/codex_manual_state.json",
    "auto_state_file": "config/codex_auto_state.json",
    "claude_health_file": "runtime/claude_health.json"
  },
  "openclaw": {
    "delegate_all_coding_tasks": true,
    "delegate_mode": "blocking",
    "runner_command": ["python3", "ai_code_runner.py"]
  },
  "tools": {
    "codex_cli": {
      "profiles": {
        "openai_native": {
          "model": "o3",
          "timeout_s": 300
        },
        "openrouter": {
          "base_url": "https://openrouter.ai/api/v1",
          "timeout_s": 300
        }
      }
    },
    "claude_code": {
      "provider": "anthropic",
      "timeout_s": 300
    }
  },
  "routing": {
    "normal": {
      "chain": [
        { "tool": "codex_cli", "backend": "openai_native", "model_profile": "codex_primary" },
        { "tool": "claude_code", "backend": "anthropic", "model_profile": "claude_primary" },
        { "tool": "codex_cli", "backend": "openrouter", "model_profile": "openrouter_dynamic" }
      ]
    },
    "last10": {
      "chain": [
        { "tool": "claude_code", "backend": "anthropic", "model_profile": "claude_primary" },
        { "tool": "codex_cli", "backend": "openrouter", "model_profile": "openrouter_dynamic" }
      ]
    }
  },
  "openrouter_dynamic_rules": {
    "default_model": "minimax",
    "specialist_rules": {
      "ui_from_screenshot": "kimi",
      "multimodal_code_task": "kimi",
      "swarm_code_task": "kimi",
      "has_screenshots": "kimi"
    }
  },
  "retry": {
    "max_retries": 2,
    "eligible_errors": [
      "auth_error",
      "rate_limited",
      "quota_exhausted",
      "provider_unavailable",
      "provider_timeout",
      "transient_network_error"
    ]
  },
  "logging": {
    "jsonl_path": "runtime/routing.jsonl"
  }
}
