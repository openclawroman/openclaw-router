{
  "budget": {
    "enabled": false,
    "period": "monthly",
    "limits": {
      "tokens": 6500000000,
      "cost_usd": 250
    },
    "thresholds": {
      "warning": 0.50,
      "critical": 0.75,
      "exhausted": 0.95
    }
  },
  "models": {
    "openrouter": {
      "minimax": "minimax/minimax-m2.7",
      "kimi": "moonshotai/kimi-k2.5",
      "mimo": "xiaomi/mimo-v2-pro"
    },
    "codex": {
      "default": "codex-default",
      "gpt54": "gpt-5.4",
      "gpt54_mini": "gpt-5.4-mini"
    },
    "claude": {
      "default": "claude-default",
      "sonnet": "claude-sonnet-4.6",
      "opus": "claude-opus-4.6"
    }
  },
  "version": 1,
  "state": {
    "default": "openai_primary",
    "manual_state_file": "config/codex_manual_state.json",
    "auto_state_file": "config/codex_auto_state.json",
    "claude_health_file": "runtime/claude_health.json"
  },
  "openclaw": {
    "delegate_all_coding_tasks": true,
    "delegate_mode": "blocking"
  },
  "tools": {
    "codex_cli": {
      "profiles": {
        "openai_native": {
          "model": "gpt-5.4",
          "timeout_s": 300
        },
        "openrouter": {
          "base_url": "https://openrouter.ai/api/v1",
          "timeout_s": 300
        }
      }
    },
    "claude_code": {
      "provider": "anthropic",
      "timeout_s": 300
    }
  },
  "routing": {
    "openai_primary": {
      "chain": [
        {
          "tool": "codex_cli",
          "backend": "openai_native",
          "model_profile": "auto"
        },
        {
          "tool": "claude_code",
          "backend": "anthropic",
          "model_profile": "claude_primary"
        },
        {
          "tool": "codex_cli",
          "backend": "openrouter",
          "model_profile": "openrouter_dynamic"
        }
      ],
      "_comment": "Reference only \u2014 chains are built programmatically by policy.py"
    },
    "openai_conservation": {
      "chain": [
        {
          "tool": "codex_cli",
          "backend": "openai_native",
          "model_profile": "auto"
        },
        {
          "tool": "codex_cli",
          "backend": "openrouter",
          "model_profile": "openrouter_minimax"
        },
        {
          "tool": "claude_code",
          "backend": "anthropic",
          "model_profile": "claude_primary"
        }
      ],
      "_comment": "Reference only \u2014 chains are built programmatically by policy.py"
    },
    "claude_backup": {
      "chain": [
        {
          "tool": "claude_code",
          "backend": "anthropic",
          "model_profile": "auto"
        },
        {
          "tool": "codex_cli",
          "backend": "openrouter",
          "model_profile": "openrouter_dynamic"
        }
      ],
      "_comment": "Reference only \u2014 chains are built programmatically by policy.py"
    },
    "openrouter_fallback": {
      "chain": [
        {
          "tool": "codex_cli",
          "backend": "openrouter",
          "model_profile": "openrouter_minimax"
        }
      ],
      "_comment": "Reference only \u2014 chains are built programmatically by policy.py"
    },
    "normal": {
      "chain": [
        {
          "tool": "codex_cli",
          "backend": "openai_native",
          "model_profile": "codex_primary"
        },
        {
          "tool": "claude_code",
          "backend": "anthropic",
          "model_profile": "claude_primary"
        },
        {
          "tool": "codex_cli",
          "backend": "openrouter",
          "model_profile": "openrouter_dynamic"
        }
      ],
      "_comment": "Reference only \u2014 chains are built programmatically by policy.py"
    },
    "last10": {
      "chain": [
        {
          "tool": "claude_code",
          "backend": "anthropic",
          "model_profile": "claude_primary"
        },
        {
          "tool": "codex_cli",
          "backend": "openrouter",
          "model_profile": "openrouter_dynamic"
        }
      ],
      "_comment": "Reference only \u2014 chains are built programmatically by policy.py"
    }
  },
  "openrouter_dynamic_rules": {
    "default_model": "minimax",
    "specialist_rules": {
      "ui_from_screenshot": "kimi",
      "multimodal_code_task": "kimi",
      "swarm_code_task": "kimi",
      "has_screenshots": "kimi"
    }
  },
  "retry": {
    "max_retries": 2,
    "eligible_errors": [
      "auth_error",
      "rate_limited",
      "quota_exhausted",
      "provider_unavailable",
      "provider_timeout",
      "transient_network_error"
    ]
  },
  "logging": {
    "jsonl_path": "runtime/routing.jsonl"
  },
  "reliability": {
    "chain_timeout_s": 600,
    "max_fallbacks": 3,
    "circuit_breaker": {
      "threshold": 5,
      "window_s": 60,
      "cooldown_s": 120
    }
  }
}
