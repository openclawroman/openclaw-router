#!/usr/bin/env python3
"""
ai-code-runner - stdin JSON entrypoint for OpenClaw coder lane.

Usage:
    cat task.json | ./ai-code-runner

Input (stdin JSON):
{
    "task_meta": {
        "task_id": "task_abc123",
        "agent": "coder",
        "task_class": "implementation",
        "risk": "medium",
        "modality": "text",
        "requires_repo_write": false,
        "requires_multimodal": false,
        "has_screenshots": false,
        "swarm": false,
        "repo_path": "/path/to/repo",
        "cwd": "/path/to/repo",
        "summary": "Implement token refresh flow"
    },
    "prompt": "Implement token refresh flow...",
    "attachments": [],
    "context": {"branch": "feature/auth", "target_files": ["src/auth.py"]}
}

Output (stdout JSON - ExecutorResult):
{
    "task_id": "task_abc123",
    "tool": "codex_cli",
    "backend": "openai_native",
    "model_profile": "codex_primary",
    "success": true,
    "normalized_error": null,
    "exit_code": 0,
    "latency_ms": 1234,
    "request_id": null,
    "cost_estimate_usd": null,
    "artifacts": [],
    "stdout_ref": null,
    "stderr_ref": null,
    "final_summary": "Token refresh flow implemented"
}
"""

import os
import sys
import json
import time
from pathlib import Path

# Add parent to path for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

# Parse config-related flags before other logic
config_path = None
for i, arg in enumerate(sys.argv):
    if arg == "--config" and i + 1 < len(sys.argv):
        config_path = sys.argv[i + 1]
    elif arg == "--env" and i + 1 < len(sys.argv):
        os.environ["ROUTER_ENV"] = sys.argv[i + 1]

if config_path:
    from router.config_loader import reload_config
    reload_config(config_path)

# Health check mode
if "--health" in sys.argv:
    from router.health import health_check
    report = health_check()
    print(json.dumps(report, indent=2))
    sys.exit(0)

# Metrics mode
if "--metrics" in sys.argv:
    from router.metrics import MetricsCollector

    period = 24
    for i, arg in enumerate(sys.argv):
        if arg == "--metrics-period" and i + 1 < len(sys.argv):
            period = int(sys.argv[i + 1])

    collector = MetricsCollector()
    report = collector.collect(period_hours=period)
    print(json.dumps(report.to_dict(), indent=2))
    sys.exit(0)

# Provider status mode
if "--status" in sys.argv:
    from router.provider_dashboard import ProviderDashboard
    import json

    dashboard = ProviderDashboard()
    report = dashboard.get_report()

    if "--json" in sys.argv:
        print(json.dumps(report.to_dict(), indent=2))
    else:
        print(report.to_table())
    sys.exit(0)

# Config validation mode
if "--validate-config" in sys.argv:
    from router.config_validator import validate_config_file
    result = validate_config_file()
    print(result.summary())
    for error in result.errors:
        print(f"  [{error.severity}] {error.path}: {error.message}")
    sys.exit(0 if result.valid else 1)

from router import (
    TaskMeta, TaskClass, TaskRisk, TaskModality,
    route_task, RoutingLogger, RouterError
)


def parse_task_meta(data: dict) -> TaskMeta:
    """Parse task_meta dict into TaskMeta, with full envelope awareness."""
    meta = data.get("task_meta", data)

    # Extract cwd from multiple possible sources (priority: cwd field > task_meta.cwd > context.working_directory)
    cwd = (
        data.get("cwd")
        or meta.get("cwd")
        or data.get("context", {}).get("working_directory")
        or data.get("context", {}).get("cwd")
        or ""
    )

    # Extract summary from prompt if not in meta
    summary = meta.get("summary", "")
    if not summary and "prompt" in data:
        summary = data["prompt"][:500]

    return TaskMeta(
        task_id=str(data.get("task_id") or meta.get("task_id", "")),
        agent=meta.get("agent", "coder"),
        task_class=TaskClass(meta.get("task_class", "implementation")),
        risk=TaskRisk(meta.get("risk", "medium")),
        modality=TaskModality(meta.get("modality", "text")),
        requires_repo_write=bool(meta.get("requires_repo_write", False)),
        requires_multimodal=bool(meta.get("requires_multimodal", False)),
        has_screenshots=bool(meta.get("has_screenshots", False)),
        swarm=bool(meta.get("swarm", False)),
        repo_path=meta.get("repo_path", ""),
        cwd=cwd,
        summary=summary,
    )


def result_to_dict(result, protocol_version=1) -> dict:
    """Convert ExecutorResult to output dict."""
    return {
        "protocol_version": protocol_version,
        "task_id": result.task_id,
        "tool": result.tool,
        "backend": result.backend,
        "model_profile": result.model_profile,
        "success": result.success,
        "normalized_error": result.normalized_error,
        "exit_code": result.exit_code,
        "latency_ms": result.latency_ms,
        "request_id": result.request_id,
        "cost_estimate_usd": result.cost_estimate_usd,
        "artifacts": result.artifacts or [],
        "stdout_ref": result.stdout_ref,
        "stderr_ref": result.stderr_ref,
        "final_summary": result.final_summary,
    }


def main():
    """Main entrypoint."""
    try:
        input_data = json.load(sys.stdin)
        task = parse_task_meta(input_data)

        # Extract scope metadata (for logging/context)
        scope = input_data.get("scope", {})
        if scope:
            os.environ["OPENCLAW_SCOPE_ID"] = str(scope.get("scope_id", ""))
            os.environ["OPENCLAW_THREAD_ID"] = str(scope.get("thread_id", "") or "")
            os.environ["OPENCLAW_SESSION_ID"] = str(scope.get("session_id", "") or "")

        # Extract context fields
        context = input_data.get("context", {})
        if context:
            os.environ["OPENCLAW_GIT_BRANCH"] = str(context.get("git_branch", "") or "")

        # Store protocol version
        protocol_version = input_data.get("protocol_version", 1)

        # Merge prompt into summary if not set
        if not task.summary and "prompt" in input_data:
            task.summary = input_data["prompt"][:500]

        # Route the task
        start_time = time.time()
        decision, result = route_task(task)
        total_latency_ms = int((time.time() - start_time) * 1000)

        # Log the decision with full envelope context
        logger = RoutingLogger()
        logger.log(task, decision, result, latency_ms=total_latency_ms)

        # Output ExecutorResult
        output = result_to_dict(result, protocol_version=protocol_version)

        print(json.dumps(output, indent=2))

    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"Invalid JSON input: {e}", "protocol_version": 1}), file=sys.stderr)
        sys.exit(1)
    except RouterError as e:
        print(json.dumps({"error": str(e), "type": type(e).__name__, "protocol_version": 1}), file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(json.dumps({"error": f"Unexpected error: {e}", "protocol_version": 1}), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
