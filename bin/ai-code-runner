#!/usr/bin/env python3
"""
ai-code-runner - stdin JSON entrypoint for OpenClaw coder lane.

Usage:
    cat task.json | ./ai-code-runner

Input (stdin JSON):
{
    "task_id": "task_abc123",
    "agent": "coder",
    "task_class": "implementation",
    "task_brief": "Implement token refresh flow",
    "repo_path": "/path/to/repo",
    "branch": "feature/auth",
    "risk": "medium",
    "criticality": "normal",
    "context_size": "medium",
    "modality": "text",
    "requires_multimodal": false,
    "has_screenshots": false,
    "swarm": false,
    "cwd": "/path/to/repo"
}

Output (stdout JSON):
{
    "task_id": "task_abc123",
    "executor": "codex_cli",
    "backend": "openai_native",
    "model_profile": "codex_primary",
    "chain": ["codex_cli", "claude_code", "openrouter"],
    "reason": "normal: standard chain",
    "attempted_fallback": false,
    "status": "success",
    "error_type": null,
    "normalized_error": null,
    "exit_code": null,
    "request_id": null,
    "cost_estimate_usd": null,
    "artifacts": [],
    "stdout_ref": null,
    "stderr_ref": null,
    "final_summary": null
}
"""

import sys
import json
import time
from pathlib import Path

# Add parent to path for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

from router import (
    TaskMeta, TaskClass, TaskRisk, TaskCriticality, TaskModality,
    route_task, RoutingLogger, RouterError
)


def parse_task(data: dict) -> TaskMeta:
    """Parse input JSON into TaskMeta."""
    return TaskMeta(
        task_id=str(data.get("task_id", "")),
        agent=data.get("agent", "coder"),
        task_class=TaskClass(data.get("task_class", "implementation")),
        task_brief=data.get("task_brief", ""),
        repo_path=data.get("repo_path", ""),
        branch=data.get("branch", "main"),
        risk=TaskRisk(data.get("risk", "medium")),
        criticality=TaskCriticality(data.get("criticality", "normal")),
        context_size=data.get("context_size", "medium"),
        modality=TaskModality(data.get("modality", "text")),
        requires_multimodal=bool(data.get("requires_multimodal", False)),
        has_screenshots=bool(data.get("has_screenshots", False)),
        swarm=bool(data.get("swarm", False)),
        cwd=data.get("cwd", ""),
    )


def build_output(decision) -> dict:
    """Build the output dict from a RouteDecision."""
    result = {
        "task_id": decision.task_id,
        "executor": decision.executor.value,
        "chain": decision.chain,
        "reason": decision.reason,
        "attempted_fallback": decision.attempted_fallback,
        "status": decision.status,
        "error_type": decision.error_type,
    }
    # New fields
    if decision.backend is not None:
        result["backend"] = decision.backend.value
    if decision.model_profile is not None:
        result["model_profile"] = decision.model_profile.value
    if decision.normalized_error is not None:
        result["normalized_error"] = decision.normalized_error
    if decision.exit_code is not None:
        result["exit_code"] = decision.exit_code
    if decision.request_id is not None:
        result["request_id"] = decision.request_id
    if decision.cost_estimate_usd is not None:
        result["cost_estimate_usd"] = decision.cost_estimate_usd
    result["artifacts"] = decision.artifacts or []
    if decision.stdout_ref is not None:
        result["stdout_ref"] = decision.stdout_ref
    if decision.stderr_ref is not None:
        result["stderr_ref"] = decision.stderr_ref
    if decision.final_summary is not None:
        result["final_summary"] = decision.final_summary
    if decision.fallback_from is not None:
        result["fallback_from"] = decision.fallback_from

    return result


def main():
    """Main entrypoint."""
    try:
        # Read stdin JSON
        input_data = json.load(sys.stdin)
        task = parse_task(input_data)

        # Route the task
        start_time = time.time()
        decision = route_task(task)
        latency_ms = int((time.time() - start_time) * 1000)

        # Log the decision
        logger = RoutingLogger()
        logger.log(task, decision, latency_ms)

        # Output result
        result = build_output(decision)
        print(json.dumps(result, indent=2))

    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"Invalid JSON input: {e}"}), file=sys.stderr)
        sys.exit(1)
    except RouterError as e:
        print(json.dumps({"error": str(e), "type": type(e).__name__}), file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(json.dumps({"error": f"Unexpected error: {e}"}), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
